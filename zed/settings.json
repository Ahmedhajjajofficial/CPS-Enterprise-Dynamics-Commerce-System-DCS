{
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "One Dark",
  "autosave": "on_focus_change",
  "restore_tabs": true,
  "show_whitespaces": "selection",
  "terminal": {
    "font_family": "Fira Code",
    "font_size": 14,
    "copy_on_selection": true,
    "env": {
      "TERM": "xterm-256color"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "binary": { "path": "rust-analyzer" },
      "initialization_options": {
        "checkOnSave": { "command": "clippy" },
        "cargo": { "allFeatures": true }
      }
    },
    "gopls": {
      "binary": { "path": "gopls" },
      "settings": { "completeUnimported": true, "staticcheck": true }
    },
    "pyright": {
      "settings": { "python": { "analysis": { "typeCheckingMode": "basic" } } }
    }
  },
  "languages": {
    "Rust": { "language_servers": ["rust-analyzer"], "format_on_save": "on" },
    "Go": { "language_servers": ["gopls"], "format_on_save": "on" },
    "Python": { "language_servers": ["pyright"], "format_on_save": "on" },
    "Java": { "language_servers": ["jdtls"], "format_on_save": "on" },
    "JavaScript": { "language_servers": ["typescript-language-server"], "format_on_save": "on" },
    "TypeScript": { "language_servers": ["typescript-language-server"], "format_on_save": "on" }
  },
  "file_scan_exclusions": [
    "**/.git/**",
    "**/target/**",
    "**/node_modules/**",
    "**/.dart_tool/**",
    "**/build/**",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.gradle/**",
    "**/dist/**"
  ]
}
